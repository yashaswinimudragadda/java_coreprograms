package programs;
import java.util.*;


class Test{
	public static void main(String [] args) {
		Deque<Integer> q = new ArrayDeque();
		q.offer(10);
		q.offer(20);
		q.offer(30);
		
		System.out.println("Queue: "+q);
		
		//dequeue
		
		System.out.println("removal: "+q.poll());
		
		//peek
		System.out.println("front: "+q.peek());
		

		
	}
}
