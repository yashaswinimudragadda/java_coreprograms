class Test{
    public static void main(String args[]){
        int n=153;
        int r=0;
        int sum=0;
        int temp=n;
        while(n>0){
            r=n%10;
            sum=sum+r*r*r;
            n=n/10;
        }
        System.out.println("===Armstrong checker===");
        if(temp==sum){
            System.out.println("Given is Armstrong number.");
        }
        else{
            System.out.println("Given is not Armstrong number.");
        }
    }
}
