class Test{
    public static void main(String args []){
        int n=121;
        int r=0;
        int sum=0;
        int t=n;
        while(n>0){
            r=n%10;
            sum=sum*10+r;
            n=n/10;
        }
        System.out.println("=======the parlindrome number checker========");
        if(t==sum){
            System.out.println("the given number is parlindrome.");
        }
        else{
            System.out.println("the given number is not parlindrome.");
        }
    }
}
