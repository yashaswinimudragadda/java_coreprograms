import java.util.*;

// Class 1: The Blueprint
class Book {
    int id;
    String name, author, publisher;
    int quantity;

    public Book(int id, String name, String author, String publisher, int quantity) {
        this.id = id;
        this.name = name;
        this.author = author;
        this.publisher = publisher;
        this.quantity = quantity;
    }
}

// Class 2: The Execution (The one you "Run")
public class Main { 
    public static void main(String[] args) {
        // Create the list
        List<Book> list = new ArrayList<Book>();

        // Create the book objects (Fixed quotes and names)
        Book b1 = new Book(101, "Let Us C", "Yashawanth", "BPB", 1);
        Book b2 = new Book(102, "Half Girlfriend", "Chetan Bhagat", "Rupa", 3);
        Book b3 = new Book(103, "Operating System", "Galvin", "Wiley", 6);

        list.add(b1);
        list.add(b2);
        list.add(b3);

        for (Book b : list) {
            System.out.println(b.id + " " + b.name + " " + b.author + " " + b.publisher + " " + b.quantity);
        }
    }
}
