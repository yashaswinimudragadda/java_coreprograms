// single inheritance program with constructors involved

package programs;

import java.lang.*;
class Emp{
    int eno;
    String ename;
    double esal;
    char egrade;
    Emp(int eno,String ename, double esal,char egrade){
        this.eno=eno;
        this.ename=ename;
        this.esal=esal;
        this.egrade=egrade;
        
    }
}
class Dept extends Emp
{
    int deptno;
     String deptname;
     Dept(int eno,String ename,double esal, char egrade, int deptno,String deptname){
         super(eno,ename,esal,egrade);
         this.deptno=deptno;
         this.deptname=deptname;
     }
     void displayvalues(){
         System.out.println(
             "Eno: "+eno+"\t"+"Ename: "+"\t"+"Esal: "+"\t"+
             "Egrade: "+egrade+"\t"+"Deptno="+deptno+"\t"+"Deptname="+deptname);

     }
     
}

class Test{
    public static void main(String args[]){
        Dept D= new Dept(101,"anil",43356.65,'A',1,"Manager");
        D.displayvalues();
    }
}
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
     
